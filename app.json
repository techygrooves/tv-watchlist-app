{
  "expo": {
    "name": "TV Watchlist",
    "slug": "tv-watchlist-app",
    "version": "1.0.0",
    "scheme": "tvwatchlist",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0D10",
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "web": {
      "output": "single",
      "bundler": "metro"
    },
    "android": {
      "package": "com.techygrooves.tvwatchlist",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
